# Optional overrides for docker-compose.yml.
#
# Copy this file to ".env" (which is git-ignored) and fill in real values.
# docker-compose automatically reads ".env" from this directory and substitutes
# these into the app service. Anything you leave out falls back to the demo
# default baked into docker-compose.yml, so the demo still runs with no .env.
#
# Apply changes with:  docker compose up -d

# Signs the login session cookies (JWT). Use a long random string.
# Generate one with:  openssl rand -hex 32
JWT_SECRET=

# Secret for the owner-only login analytics endpoint:
#   GET /api/stats?token=<STATS_TOKEN>
STATS_TOKEN=

# Host port to serve the demo on (browser -> http://localhost:<APP_PORT>).
# The container always listens on 3000 internally.
APP_PORT=3000
